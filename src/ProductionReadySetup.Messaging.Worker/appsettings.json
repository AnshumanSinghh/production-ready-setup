{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Observability": {
    "ServiceName": "messaging-worker",
    "Environment": "development",
    "Version": "1.0.0",
    "MinimumLevel": "Debug",
    "MicrosoftLevel": "Warning",
    "WriteToConsoleJson": false,
    "WriteToFile": false,
    "EnableRequestLogging": false
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "UseTls": false,
    "HeartbeatSeconds": 30,
    "AutomaticRecoveryEnabled": true,
    "NetworkRecoveryIntervalSeconds": 10,
    "OrdersExchange": "production-ready.orders",
    "OrdersDeadLetterExchange": "production-ready.orders.dlx",
    "OrderCreatedQueue": "orders.created",
    "OrderCreatedDeadLetterQueue": "orders.created.dlq",
    "OrderCreatedRoutingKey": "orders.created",
    "ActivelyDeclareTopology": true
  },
  "Consumer": {
    "PrefetchCount": 10,
    "MaxRetryAttempts": 3,
    "BaseRetryDelayMs": 500,
    "GracefulShutdownTimeoutSeconds": 45,
    "IdempotencyTtlSeconds": 86400
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  }
}
