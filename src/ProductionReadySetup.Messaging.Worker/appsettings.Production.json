{
  "Observability": {
    "Environment": "production",
    "MinimumLevel": "Information",
    "WriteToConsoleJson": true,
    "WriteToFile": false
  },
  "RabbitMq": {
    "UseTls": true,
    "AutomaticRecoveryEnabled": true,
    "ActivelyDeclareTopology": false
  },
  "Consumer": {
    "PrefetchCount": 50,
    "MaxRetryAttempts": 3,
    "BaseRetryDelayMs": 500,
    "GracefulShutdownTimeoutSeconds": 45
  }
}