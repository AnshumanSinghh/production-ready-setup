{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "ServiceName": "messaging-api",
    "Environment": "development",
    "Version": "1.0.0",
    "MinimumLevel": "Debug",
    "MicrosoftLevel": "Warning",
    "WriteToConsoleJson": false,
    "WriteToFile": false,
    "EnableRequestLogging": true,
    "RequestLoggingExcludedPaths": [
      "/health",
      "/health/live",
      "/health/ready",
      "/metrics",
      "/favicon.ico"
    ]
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "UseTls": false,
    "HeartbeatSeconds": 30,
    "AutomaticRecoveryEnabled": true,
    "NetworkRecoveryIntervalSeconds": 10,
    "OrdersExchange": "production-ready.orders",
    "OrdersDeadLetterExchange": "production-ready.orders.dlx",
    "OrderCreatedQueue": "orders.created",
    "OrderCreatedDeadLetterQueue": "orders.created.dlq",
    "OrderCreatedRoutingKey": "orders.created",
    "ActivelyDeclareTopology": true
  },
  "AllowedHosts": "*"
}
