// appsettings.Production.json — Overrides for production
// WHY separate file: WriteToConsoleJson = true for container stdout.
// Never write to file in containers — ephemeral filesystem.
{
  "Observability": {
    "Environment": "production",
    "MinimumLevel": "Information",
    "MicrosoftLevel": "Warning",
    "WriteToConsoleJson": true,
    "WriteToFile": false,
    "EnableRequestLogging": true
  }
}